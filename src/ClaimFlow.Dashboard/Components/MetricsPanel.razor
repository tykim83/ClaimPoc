@using ClaimFlow.Dashboard.Services
@inject MetricsClient Metrics
@rendermode InteractiveServer

<section class="metrics-card">
    <header class="metrics-head" @onclick="Toggle">
        <span class="chevron @(expanded ? "open" : "")">▶</span>
        <span class="metrics-title">Pipeline metrics</span>
        <span class="muted metrics-sub">the counters we emit (claimflow.*)</span>
        <button class="ghost metrics-refresh" @onclick="Refresh" @onclick:stopPropagation="true" disabled="@loading">
            @(loading ? "…" : "Refresh")
        </button>
        <button class="ghost metrics-refresh" @onclick="Clear" @onclick:stopPropagation="true" disabled="@loading">
            Clear
        </button>
    </header>

    @if (expanded)
    {
        <div class="metrics-body">
            @if (snapshot is null)
            {
                <p class="muted">Loading…</p>
            }
            else if (!snapshot.Available)
            {
                <p class="muted">Metrics unavailable: @snapshot.Error</p>
            }
            else if (snapshot.Points.Count == 0)
            {
                <p class="muted">No metrics yet — start a run.</p>
            }
            else
            {
                <p class="muted small">Received counts each claim once (retries not recounted). Failed = handled failures, the claim was closed properly. Dead-lettered = silently lost; that bar being non-zero is the alarm.</p>
                <ApexChart @key="@version" TItem="MetricPoint" Options="options" Height="320">
                    @foreach (var measure in AllMeasures)
                    {
                        <ApexPointSeries TItem="MetricPoint"
                                         Items="@Series(measure)"
                                         Name="@MeasureLabel(measure)"
                                         XValue="@(p => Label(p.Stage))"
                                         YValue="@(p => (decimal)p.Value)"
                                         SeriesType="SeriesType.Bar" />
                    }
                </ApexChart>

                @if (BrickLoss() is { Count: > 0 } losses)
                {
                    <div class="dlq-strip">
                        <span class="muted small dlq-label">Dead-lettered per brick (claims that entered and never responded):</span>
                        @foreach (var (brick, lost) in losses)
                        {
                            <span class="pill @(lost > 0 ? "fail" : "ok")">@Cap(brick): @lost</span>
                        }
                    </div>
                }
            }
        </div>
    }
</section>

@code {
    private bool expanded = true;
    private bool loading;
    private int version;
    private MetricsSnapshot? snapshot;

    // Always render the same four series in the same order, zero-filled when a counter
    // hasn't fired yet. Series and Colors are matched by position, so a measure missing
    // from the scrape would otherwise shift the colors (e.g. dead-lettered turning amber).
    private static readonly string[] AllMeasures = ["received", "processed", "failed", "deadlettered"];

    private readonly ApexChartOptions<MetricPoint> options = new()
    {
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = false, BorderRadius = 3, ColumnWidth = "65%" } },
        Legend = new Legend { Position = LegendPosition.Bottom },
        DataLabels = new DataLabels { Enabled = false },
        Colors = ["#4f46e5", "#15a34a", "#f59e0b", "#e0322f"],
        Grid = new Grid { BorderColor = "#eef1f5" },
    };

    // Bricks are visually separated from Comms/Tasks by an empty spacer column.
    private static readonly string[] Bricks = ["classifier", "preparer", "filer"];
    private const string Spacer = " "; // em space: a unique category that renders blank

    private List<string> order = [];

    protected override Task OnInitializedAsync() => Refresh();

    private void Toggle() => expanded = !expanded;

    private async Task Refresh()
    {
        loading = true;
        snapshot = await Metrics.GetAsync();
        order = BuildOrder(snapshot);
        version++;
        loading = false;
    }

    // Zero the charts from now on: records the current totals as the baseline, then reloads
    // so everything reads back at 0 until the next run increments the counters.
    private async Task Clear()
    {
        loading = true;
        await Metrics.ClearAsync();
        await Refresh();
    }

    // Stage order for the X axis: whatever the snapshot has (already ranked), with one
    // blank column inserted between Tasks and the first brick.
    private static List<string> BuildOrder(MetricsSnapshot? snap)
    {
        var result = new List<string>();
        if (snap is null) return result;
        var hasTasks = snap.Stages.Contains("tasks");
        var spacerAdded = false;
        foreach (var stage in snap.Stages)
        {
            if (hasTasks && !spacerAdded && Bricks.Contains(stage))
            {
                result.Add(Spacer);
                spacerAdded = true;
            }
            result.Add(stage);
        }
        return result;
    }

    // One point per X-axis column, in axis order — including 0s for columns this measure
    // doesn't have (e.g. comms has no "failed") and for the blank spacer. Every series must
    // span the SAME categories in the SAME order, otherwise ApexCharts aligns bars by
    // position and they shift where a stage is missing a measure.
    private IEnumerable<MetricPoint> Series(string measure)
    {
        var byStage = snapshot!.Points
            .Where(p => p.Measure == measure)
            .ToDictionary(p => p.Stage, p => p.Value);
        return order.Select(stage => new MetricPoint(stage, measure, byStage.GetValueOrDefault(stage)));
    }

    // Each brick counts its own DLQ arrivals (one per lost claim), so this is a direct
    // read — no cross-stage math, no retry noise.
    private List<(string Brick, long Lost)> BrickLoss() =>
        Bricks.Where(b => snapshot!.Stages.Contains(b))
              .Select(b => (b, Val(b, "deadlettered")))
              .ToList();

    private long Val(string stage, string measure) =>
        snapshot!.Points.FirstOrDefault(p => p.Stage == stage && p.Measure == measure)?.Value ?? 0;

    private static string Label(string stage) => stage == Spacer ? Spacer : Cap(stage);

    private static string MeasureLabel(string measure) => measure == "deadlettered" ? "Dead-lettered" : Cap(measure);

    private static string Cap(string s) => string.IsNullOrEmpty(s) ? s : char.ToUpperInvariant(s[0]) + s[1..];
}
