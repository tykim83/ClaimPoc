@using ClaimFlow.Dashboard.Services
@inject MetricsClient Metrics
@rendermode InteractiveServer

<section class="metrics-card">
    <header class="metrics-head" @onclick="Toggle">
        <span class="chevron @(expanded ? "open" : "")">▶</span>
        <span class="metrics-title">Pipeline metrics</span>
        @if (snapshot is { Available: true })
        {
            <span class="muted metrics-sub">@snapshot.Funnel[0].Count started · @snapshot.Completed completed · @snapshot.Failed failed</span>
        }
        <button class="ghost metrics-refresh" @onclick="Refresh" @onclick:stopPropagation="true" disabled="@loading">
            @(loading ? "…" : "Refresh")
        </button>
    </header>

    @if (expanded)
    {
        <div class="metrics-body">
            @if (snapshot is null)
            {
                <p class="muted">Loading…</p>
            }
            else if (!snapshot.Available)
            {
                <p class="muted">Metrics unavailable: @snapshot.Error</p>
            }
            else
            {
                <div class="charts">
                    <div class="chart-box">
                        <h3>Stage funnel</h3>
                        <p class="muted small">Each stage only receives what the previous one forwarded — a step down is where claims were lost.</p>
                        <ApexChart @key="@version" TItem="FunnelStage" Options="funnelOptions" Height="230">
                            <ApexPointSeries TItem="FunnelStage"
                                             Items="snapshot.Funnel"
                                             Name="Claims"
                                             XValue="@(s => s.Stage)"
                                             YValue="@(s => (decimal)s.Count)"
                                             SeriesType="SeriesType.Bar" />
                        </ApexChart>
                    </div>

                    <div class="chart-box">
                        <h3>Outcome</h3>
                        <p class="muted small">Completed vs failed. The gap to "started" is silent loss.</p>
                        <ApexChart @key="@version" TItem="Slice" Options="donutOptions" Height="230">
                            <ApexPointSeries TItem="Slice"
                                             Items="Slices"
                                             Name="Claims"
                                             XValue="@(s => s.Label)"
                                             YValue="@(s => (decimal)s.Value)"
                                             SeriesType="SeriesType.Donut" />
                        </ApexChart>
                    </div>
                </div>
            }
        </div>
    }
</section>

@code {
    private record Slice(string Label, long Value);

    private bool expanded = true;
    private bool loading;
    private int version;
    private MetricsSnapshot? snapshot;

    private IEnumerable<Slice> Slices => snapshot is null
        ? []
        : [new("Completed", snapshot.Completed), new("Failed", snapshot.Failed)];

    private readonly ApexChartOptions<FunnelStage> funnelOptions = new()
    {
        PlotOptions = new PlotOptions { Bar = new PlotOptionsBar { Horizontal = true, BorderRadius = 4 } },
        DataLabels = new DataLabels { Enabled = true },
        Colors = ["#4f46e5"],
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
        Grid = new Grid { BorderColor = "#eef1f5" },
    };

    private readonly ApexChartOptions<Slice> donutOptions = new()
    {
        Colors = ["#15a34a", "#e0322f"],
        Legend = new Legend { Position = LegendPosition.Bottom },
        Chart = new Chart { Toolbar = new Toolbar { Show = false } },
    };

    protected override Task OnInitializedAsync() => Refresh();

    private void Toggle() => expanded = !expanded;

    private async Task Refresh()
    {
        loading = true;
        snapshot = await Metrics.GetAsync();
        version++;
        loading = false;
    }
}
