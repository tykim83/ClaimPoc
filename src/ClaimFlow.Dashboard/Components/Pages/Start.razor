@page "/"
@using ClaimFlow.Dashboard.Services
@inject ClaimStarter Starter
@rendermode InteractiveServer

<PageTitle>Start runs</PageTitle>

<h1>Start claim runs</h1>

<p class="muted">Calls the Comms intake endpoint (<code>s1-comms</code>) once per run — same path as a real email. Comms creates the CorrelationId and kicks off the orchestration.</p>

<div class="controls">
    <label>How many:
        <input type="number" min="1" max="1000" @bind="count" />
    </label>
    <button @onclick="StartRuns" disabled="@busy">@(busy ? "Starting…" : "Start")</button>

    <div class="presets">
        <button class="ghost" @onclick="() => count = 1" disabled="@busy">1</button>
        <button class="ghost" @onclick="() => count = 10" disabled="@busy">10</button>
        <button class="ghost" @onclick="() => count = 100" disabled="@busy">100</button>
        <button class="ghost" @onclick="() => count = 1000" disabled="@busy">1000</button>
    </div>
</div>

@if (message is not null)
{
    <p class="result">@message</p>
}

@code {
    private int count = 1;
    private bool busy;
    private string? message;

    private async Task StartRuns()
    {
        count = Math.Clamp(count, 1, 1000);
        busy = true;
        message = null;
        try
        {
            var sent = await Starter.StartAsync(count);
            message = $"Started {sent} run(s).";
        }
        catch (Exception ex)
        {
            message = $"Failed: {ex.Message}";
        }
        finally
        {
            busy = false;
        }
    }
}
